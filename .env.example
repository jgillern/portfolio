# Shared, safe placeholders only. Never commit real values.
APP_ENV=development
DATA_MODE=synthetic

# portfolio-app: read-only database role
DATABASE_READ_URL=postgresql://portfolio_app:replace-me@replace-me/portfolio?sslmode=require
SESSION_SIGNING_KEY=replace-with-at-least-32-random-bytes
OWNER_PASSWORD_SALT=replace-with-random-base64
OWNER_PASSWORD_HASH=replace-with-pbkdf2-sha256-hex
MCP_BEARER_TOKEN_HASH=replace-with-sha256-hex
WORKER_BASE_URL=https://portfolio-worker.example
WORKER_SIGNING_KEY=replace-with-at-least-32-random-bytes

# portfolio-worker: production-only write role and secrets
DATABASE_WRITE_URL=postgresql://portfolio_worker:replace-me@replace-me/portfolio?sslmode=require
MASTER_ENCRYPTION_KEY=replace-with-32-random-bytes-base64
CRON_SECRET=replace-me
BLOB_READ_WRITE_TOKEN=replace-me
GMAIL_CLIENT_ID=replace-me
GMAIL_CLIENT_SECRET=replace-me
GMAIL_REDIRECT_URI=https://portfolio-worker.example/api/oauth/gmail/callback

# Optional market-data providers
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
